# Supabase project settings (Project Settings > API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never expose to the client. Used by API routes for
# authoritative reads/writes that bypass Row-Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Full Postgres connection string, including password, via the transaction
# pooler (dashboard: Connect > Transaction pooler). Not used by the app
# itself — only needed locally to run `supabase db push` / `migration list`
# against the remote database.
DATABASE_MIGRATION_URL=postgresql://postgres.your-project:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres
